\
# Generated into src/Makevars by ../configure. See ../configure for how
# the substituted CPPFLAGS/LIBS values below are determined.
#
# -Icompat comes first so vendored osmium-tool files' own
# `#include <boost/program_options.hpp>` resolves to osmiumr's
# header-only shim (compat/boost/program_options.hpp) instead of any
# real Boost that might also be present on the include path -- see that
# file for why a real boost::program_options is not used.
#
# The three -Ivendor/... entries are libosmium/nlohmann-json/protozero,
# vendored verbatim under src/vendor/ (see src/vendor/README.md) rather
# than detected on the system -- unlike @osmiumr_cppflags@ below, these
# paths are the same on every platform, which is what makes Windows
# builds possible at all for these three (see ../plan-windows.md).

PKG_CPPFLAGS = -Icompat -Ivendor/libosmium/include -Ivendor/nlohmann/include -Ivendor/protozero/include @osmiumr_cppflags@ -I.
PKG_LIBS = @osmiumr_libs@

CXX_STD = CXX17

# Size reduction -- see ../plan-reduce-size.md. @osmiumr_libs@ above
# includes a linker flag ../configure probes for (trying
# -Wl,--strip-debug, then -Wl,-S, then giving up) to strip debugging
# metadata from the final .so at link time: measured 19MB unstripped,
# 8.1MB with it. Not hardcoded here: -Wl,--strip-debug is GNU ld/gold/
# lld syntax that Apple's ld64 (macOS) doesn't understand and hard-fails
# the *entire* link on -- this previously shipped hardcoded as
# -Wl,--strip-debug right in this file and broke every macOS install
# ("ld: unknown options: --strip-debug"). Probing for a working flag at
# configure time instead of hardcoding one (Linux-only assumption) or
# the other (untested elsewhere) is what ../configure now does.
#
# Tried and dropped: -ffunction-sections/-fdata-sections (compile time)
# + -Wl,--gc-sections (link time), meant to let the linker discard
# whole per-function/per-variable sections nothing references -- in
# principle a big win given how much of the compiled code comes from
# two large header-only template libraries (libosmium, nlohmann/json,
# see src/vendor/) that get instantiated per translation unit
# regardless of whether a given osmiumr command path ever actually
# calls them. Measured essentially no size difference on top of
# --strip-debug alone in this toolchain (the linker was apparently
# already collapsing most of that via COMDAT folding), while
# -ffunction-sections/-fdata-sections trips R CMD check's "checking
# compilation flags in Makevars" portability WARNING regardless of
# which PKG_*FLAGS variable it's placed in -- not worth carrying a
# permanent WARNING for a flag pair with no measured benefit here.
# Worth re-measuring if this package's vendored source grows enough
# that per-function GC might start to matter (a different compiler/
# linker than tested here could also behave differently).
#
# Deliberately --strip-debug, not a full --strip-all/-s: the latter
# also strips the regular (non-debug) symbol table, which measured
# smaller still (5.4MB) but broke R CMD check's own "checking compiled
# code" step (it runs `nm` on the built .so looking for problem
# symbols -- with none left to find, it can't do that check at all,
# and reports so as a new NOTE). Same principle as not suppressing
# compiler diagnostics via pragmas elsewhere in this package: don't
# ship something that defeats CRAN's own ability to inspect the
# compiled code, even in service of a smaller binary.

# Explicit source list rather than $(wildcard ...): CRAN's portability
# checks flag GNU Make extensions like $(wildcard ...) in package
# Makevars, so this is kept in sync by hand with src/osmium-tool/ (see
# ../plan.md for which osmium-tool files are vendored and why).
OSMIUM_TOOL_SOURCES = \
    osmium-tool/cmd.cpp \
    osmium-tool/cmd_factory.cpp \
    osmium-tool/commands.cpp \
    osmium-tool/command_cat.cpp \
    osmium-tool/command_export.cpp \
    osmium-tool/command_extract.cpp \
    osmium-tool/command_fileinfo.cpp \
    osmium-tool/command_getid.cpp \
    osmium-tool/command_help.cpp \
    osmium-tool/command_merge.cpp \
    osmium-tool/command_sort.cpp \
    osmium-tool/command_tags_filter.cpp \
    osmium-tool/id_file.cpp \
    osmium-tool/io.cpp \
    osmium-tool/option_clean.cpp \
    osmium-tool/util.cpp \
    osmium-tool/version.cpp \
    osmium-tool/export/export_format_json.cpp \
    osmium-tool/export/export_format_pg.cpp \
    osmium-tool/export/export_format_text.cpp \
    osmium-tool/export/export_handler.cpp \
    osmium-tool/extract/extract.cpp \
    osmium-tool/extract/extract_bbox.cpp \
    osmium-tool/extract/extract_polygon.cpp \
    osmium-tool/extract/geojson_file_parser.cpp \
    osmium-tool/extract/geometry_util.cpp \
    osmium-tool/extract/osm_file_parser.cpp \
    osmium-tool/extract/poly_file_parser.cpp \
    osmium-tool/extract/strategy_complete_ways.cpp \
    osmium-tool/extract/strategy_complete_ways_with_history.cpp \
    osmium-tool/extract/strategy_simple.cpp \
    osmium-tool/extract/strategy_smart.cpp

SOURCES = r_bridge.cpp RcppExports.cpp $(OSMIUM_TOOL_SOURCES)
OBJECTS = $(SOURCES:.cpp=.o)
