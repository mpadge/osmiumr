#!/bin/sh
# Removes files generated by ./configure and by compilation, so a fresh
# `R CMD build` doesn't ship a stale src/Makevars (generated for whatever
# machine last ran configure in this tree) or leftover object files.
rm -f src/Makevars src/Makevars.win
rm -f src/*.o src/*.so src/*.dll
rm -f src/osmium-tool/*.o
rm -f src/osmium-tool/extract/*.o
rm -f src/osmium-tool/export/*.o
