#!/bin/sh
# osmiumr configure script.
#
# Locates the system libraries osmium-tool's own CMakeLists.txt requires
# that osmiumr does NOT vendor, and writes src/Makevars from
# src/Makevars.in.
#
# libosmium, protozero, and nlohmann-json are all header-only and are
# vendored under src/vendor/ (see src/vendor/README.md), so there is
# nothing to detect for them on any platform -- that's also what makes
# building on Windows possible at all: there's no standard system
# location for these on Windows the way there is on Linux/macOS, so
# vendoring removes the whole class of problem rather than trying to
# solve it (see ../plan-windows.md).
#
# What's left needing detection is bz2/zlib/expat (+ optional lz4),
# which are compiled libraries, not headers, so can't be vendored the
# same way. The one dependency osmium-tool itself needs but this
# package does not is boost::program_options: osmiumr ships its own
# header-only stand-in (src/compat/boost/program_options.hpp) for the
# small subset of that API the vendored command_*.cpp setup() methods use,
# so there is nothing to detect or link for Boost at all -- see that file
# for the rationale.

set -e

CXX=$(${R_HOME}/bin/R CMD config CXX17 2>/dev/null || true)
if [ -z "$CXX" ]; then
    CXX=$(${R_HOME}/bin/R CMD config CXX 2>/dev/null || true)
fi
CXXFLAGS=$(${R_HOME}/bin/R CMD config CXX17FLAGS 2>/dev/null || ${R_HOME}/bin/R CMD config CXXFLAGS 2>/dev/null || true)

CANDIDATE_INCLUDE_DIRS="/usr/include /usr/local/include /opt/homebrew/include /opt/local/include"
CANDIDATE_LIB_DIRS="/usr/lib /usr/lib64 /usr/local/lib /opt/homebrew/lib /opt/local/lib /usr/lib/x86_64-linux-gnu"

fail() {
    echo "*** configure: $1" >&2
    exit 1
}

find_header() {
    # find_header <relative/header/path> [extra dirs...]
    hdr="$1"
    shift
    for d in "$@" $CANDIDATE_INCLUDE_DIRS; do
        if [ -f "$d/$hdr" ]; then
            echo "$d"
            return 0
        fi
    done
    return 1
}

find_lib() {
    # find_lib <libname without lib prefix/suffix>
    name="$1"
    for d in $CANDIDATE_LIB_DIRS; do
        for ext in so a dylib; do
            if [ -f "$d/lib${name}.${ext}" ]; then
                echo "$d"
                return 0
            fi
        done
        for f in "$d"/lib${name}.so.*; do
            if [ -f "$f" ]; then
                echo "$d"
                return 0
            fi
        done
    done
    return 1
}

echo "--- osmiumr configure ---"

# --- bz2, zlib, expat ------------------------------------------------------
BZ2_INC=$(find_header "bzlib.h") || fail "bzlib.h not found. Install libbz2-dev."
BZ2_LIB_DIR=$(find_lib "bz2") || fail "libbz2 not found. Install libbz2-dev."

ZLIB_INC=$(find_header "zlib.h") || fail "zlib.h not found. Install zlib1g-dev."
ZLIB_LIB_DIR=$(find_lib "z") || fail "libz not found. Install zlib1g-dev."

EXPAT_INC=$(find_header "expat.h") || fail "expat.h not found. Install libexpat1-dev."
EXPAT_LIB_DIR=$(find_lib "expat") || fail "libexpat not found. Install libexpat1-dev."

# --- lz4 (optional) --------------------------------------------------------
LZ4_DEFS=""
LZ4_LIBS=""
LZ4_INC=$(find_header "lz4.h" "${LZ4_INCLUDE_DIR}" || true)
LZ4_LIB_DIR=$(find_lib "lz4" || true)
if [ -n "$LZ4_INC" ] && [ -n "$LZ4_LIB_DIR" ]; then
    echo "Found lz4 in $LZ4_INC / $LZ4_LIB_DIR - building with LZ4 PBF compression support"
    LZ4_DEFS="-DOSMIUM_WITH_LZ4"
    LZ4_CPPFLAGS="-I$LZ4_INC"
    LZ4_LIBS="-L$LZ4_LIB_DIR -llz4"
else
    echo "lz4 not found - building without LZ4 PBF compression support"
    LZ4_CPPFLAGS=""
fi

PKG_CPPFLAGS="-I$BZ2_INC -I$ZLIB_INC -I$EXPAT_INC $LZ4_CPPFLAGS $LZ4_DEFS"
PKG_LIBS="-L$BZ2_LIB_DIR -lbz2 -L$ZLIB_LIB_DIR -lz -L$EXPAT_LIB_DIR -lexpat $LZ4_LIBS -lpthread"

echo "PKG_CPPFLAGS=$PKG_CPPFLAGS"
echo "PKG_LIBS=$PKG_LIBS"

sed -e "s|@osmiumr_cppflags@|$PKG_CPPFLAGS|" \
    -e "s|@osmiumr_libs@|$PKG_LIBS|" \
    src/Makevars.in > src/Makevars

echo "--- osmiumr configure: done ---"
