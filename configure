#!/bin/sh
# rosmium configure script.
#
# Locates the system libraries osmium-tool's own CMakeLists.txt requires
# that rosmium does NOT vendor, and writes src/Makevars from
# src/Makevars.in.
#
# libosmium, protozero, and nlohmann-json are all header-only and are
# vendored under src/vendor/ (see src/vendor/README.md), so there is
# nothing to detect for them on any platform -- that's also what makes
# building on Windows possible at all: there's no standard system
# location for these on Windows the way there is on Linux/macOS, so
# vendoring removes the whole class of problem rather than trying to
# solve it (see ../plan-windows.md).
#
# What's left needing detection is bz2/zlib/expat (+ optional lz4),
# which are compiled libraries, not headers, so can't be vendored the
# same way. The one dependency osmium-tool itself needs but this
# package does not is boost::program_options: rosmium ships its own
# header-only stand-in (src/compat/boost/program_options.hpp) for the
# small subset of that API the vendored command_*.cpp setup() methods use,
# so there is nothing to detect or link for Boost at all -- see that file
# for the rationale.

set -e

CXX=$(${R_HOME}/bin/R CMD config CXX17 2>/dev/null || true)
if [ -z "$CXX" ]; then
    CXX=$(${R_HOME}/bin/R CMD config CXX 2>/dev/null || true)
fi
CXXFLAGS=$(${R_HOME}/bin/R CMD config CXX17FLAGS 2>/dev/null || ${R_HOME}/bin/R CMD config CXXFLAGS 2>/dev/null || true)

CANDIDATE_INCLUDE_DIRS="/usr/include /usr/local/include /opt/homebrew/include /opt/local/include"
CANDIDATE_LIB_DIRS="/usr/lib /usr/lib64 /usr/local/lib /opt/homebrew/lib /opt/local/lib /usr/lib/x86_64-linux-gnu"

# Homebrew's bzip2 formula is keg-only on macOS (the OS already ships a
# bzip2, so brew won't symlink its own into the standard prefix), so
# `brew install bzip2` alone leaves bzlib.h/libbz2 outside
# CANDIDATE_INCLUDE_DIRS/CANDIDATE_LIB_DIRS above. Ask brew directly for
# its keg-only prefix and add that too.
if command -v brew >/dev/null 2>&1; then
    BZ2_BREW_PREFIX=$(brew --prefix bzip2 2>/dev/null || true)
    if [ -n "$BZ2_BREW_PREFIX" ]; then
        CANDIDATE_INCLUDE_DIRS="$CANDIDATE_INCLUDE_DIRS $BZ2_BREW_PREFIX/include"
        CANDIDATE_LIB_DIRS="$CANDIDATE_LIB_DIRS $BZ2_BREW_PREFIX/lib"
    fi
fi

# zlib and expat are macOS system libraries. Since Catalina, Apple no
# longer ships their headers under /usr/include; since Big Sur, the
# actual .dylib files aren't on disk at all (they only live in the dyld
# shared cache) -- the only linkable artifact left is a .tbd stub inside
# the active Xcode/Command Line Tools SDK sysroot. Ask xcrun for that SDK
# path and add both its usr/include and usr/lib.
if command -v xcrun >/dev/null 2>&1; then
    SDK_PATH=$(xcrun --show-sdk-path 2>/dev/null || true)
    if [ -n "$SDK_PATH" ]; then
        CANDIDATE_INCLUDE_DIRS="$CANDIDATE_INCLUDE_DIRS $SDK_PATH/usr/include"
        CANDIDATE_LIB_DIRS="$CANDIDATE_LIB_DIRS $SDK_PATH/usr/lib"
    fi
fi

fail() {
    echo "*** configure: $1" >&2
    exit 1
}

find_header() {
    # find_header <relative/header/path> [extra dirs...]
    hdr="$1"
    shift
    for d in "$@" $CANDIDATE_INCLUDE_DIRS; do
        if [ -f "$d/$hdr" ]; then
            echo "$d"
            return 0
        fi
    done
    return 1
}

find_lib() {
    # find_lib <libname without lib prefix/suffix>
    name="$1"
    for d in $CANDIDATE_LIB_DIRS; do
        for ext in so a dylib tbd; do
            if [ -f "$d/lib${name}.${ext}" ]; then
                echo "$d"
                return 0
            fi
        done
        for f in "$d"/lib${name}.so.*; do
            if [ -f "$f" ]; then
                echo "$d"
                return 0
            fi
        done
    done
    return 1
}

echo "--- rosmium configure ---"

# --- bz2, zlib, expat ------------------------------------------------------
BZ2_INC=$(find_header "bzlib.h") || fail "bzlib.h not found. Install libbz2-dev."
BZ2_LIB_DIR=$(find_lib "bz2") || fail "libbz2 not found. Install libbz2-dev."

ZLIB_INC=$(find_header "zlib.h") || fail "zlib.h not found. Install zlib1g-dev."
ZLIB_LIB_DIR=$(find_lib "z") || fail "libz not found. Install zlib1g-dev."

EXPAT_INC=$(find_header "expat.h") || fail "expat.h not found. Install libexpat1-dev."
EXPAT_LIB_DIR=$(find_lib "expat") || fail "libexpat not found. Install libexpat1-dev."

# --- lz4 (optional) --------------------------------------------------------
LZ4_DEFS=""
LZ4_LIBS=""
LZ4_INC=$(find_header "lz4.h" "${LZ4_INCLUDE_DIR}" || true)
LZ4_LIB_DIR=$(find_lib "lz4" || true)
if [ -n "$LZ4_INC" ] && [ -n "$LZ4_LIB_DIR" ]; then
    echo "Found lz4 in $LZ4_INC / $LZ4_LIB_DIR - building with LZ4 PBF compression support"
    LZ4_DEFS="-DOSMIUM_WITH_LZ4"
    LZ4_CPPFLAGS="-I$LZ4_INC"
    LZ4_LIBS="-L$LZ4_LIB_DIR -llz4"
else
    echo "lz4 not found - building without LZ4 PBF compression support"
    LZ4_CPPFLAGS=""
fi

# --- link-time debug-info stripping flag (best-effort) ---------------------
# Size reduction (see ../plan-reduce-size.md): strip debug info from the
# final shared library at link time. GNU ld/gold/lld understand
# --strip-debug; Apple's ld64 (macOS) does not and hard-fails the *entire*
# link if given it -- this previously shipped hardcoded as
# -Wl,--strip-debug directly in Makevars.in and broke every macOS install
# (00install.out: "ld: unknown options: --strip-debug"). -S is accepted
# by both GNU ld and ld64, but rather than swap one hardcoded assumption
# for another and risk the same surprise on some other linker later,
# probe for a working flag empirically instead of assuming either way.
STRIP_LDFLAGS=""
STRIPTEST_DIR=$(mktemp -d 2>/dev/null || echo /tmp)
echo 'int main() { return 0; }' > "$STRIPTEST_DIR/striptest.cpp"
for flag in -Wl,--strip-debug -Wl,-S; do
    # $CXX deliberately unquoted: R CMD config CXX17 can return a
    # multi-word command (e.g. "ccache clang++"), and quoting it here
    # makes the shell look for a single binary literally named
    # "ccache clang++", silently failing every flag in this loop.
    if $CXX -o "$STRIPTEST_DIR/striptest" $flag "$STRIPTEST_DIR/striptest.cpp" > /dev/null 2>&1; then
        STRIP_LDFLAGS="$flag"
        echo "Using $flag to strip debug info from the built shared library"
        break
    fi
done
if [ -z "$STRIP_LDFLAGS" ]; then
    echo "Note: no working linker flag found to strip debug info (tried --strip-debug, -S) - rosmium.so will be larger than necessary, see plan-reduce-size.md"
fi
rm -rf "$STRIPTEST_DIR"

PKG_CPPFLAGS="-I$BZ2_INC -I$ZLIB_INC -I$EXPAT_INC $LZ4_CPPFLAGS $LZ4_DEFS"
PKG_LIBS="-L$BZ2_LIB_DIR -lbz2 -L$ZLIB_LIB_DIR -lz -L$EXPAT_LIB_DIR -lexpat $LZ4_LIBS -lpthread $STRIP_LDFLAGS"

echo "PKG_CPPFLAGS=$PKG_CPPFLAGS"
echo "PKG_LIBS=$PKG_LIBS"

sed -e "s|@rosmium_cppflags@|$PKG_CPPFLAGS|" \
    -e "s|@rosmium_libs@|$PKG_LIBS|" \
    src/Makevars.in > src/Makevars

echo "--- rosmium configure: done ---"
